{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["src/**", "package.json", "tsconfig.json"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
            "cache": true
        },
        "test": {
            "dependsOn": ["build"],
            "inputs": ["src/**", "tests/**"],
            "cache": true
        },
        "lint": {
            "dependsOn": ["build"],
            "inputs": ["src/**"],
            "cache": true
        },
        "clean": {
            "cache": false
        }
    }
}